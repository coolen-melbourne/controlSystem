        items.forEach(i=>{const m=i.modelName||'Noma\'lum';if(!groups[m])groups[m]=[];groups[m].push(i);});
        let html='';
        for(const[mn,its]of Object.entries(groups)){html+=`<div class="mb-6"><h4 class="font-bold text-lg mb-2">📦 ${escapeHtml(mn)}</h4><table class="w-full text-sm"><thead><tr class="bg-gray-100"><th class="p-2">Variant</th><th class="p-2">Zakaz</th><th class="p-2">Band</th><th class="p-2 text-right">Miqdor</th><th class="p-2">Sana</th></tr></thead><tbody>`;its.forEach(i=>{html+=`<tr><td class="p-2">${escapeHtml(i.variant||'—')}</td><td class="p-2">${escapeHtml(i.orderNumber||'—')}</td><td class="p-2">${escapeHtml(i.band||'—')}</td><td class="p-2 text-right">${i.quantity}</td><td class="p-2">${new Date(i.date).toLocaleDateString()}</td></tr>`;});html+=`</tbody></table></div>`;}
        c.innerHTML=html;
      } catch(e){c.innerHTML='<div class="text-red-500 text-center">Xatolik</div>';}
    }

    async function showAccessoriesModal() {
      const modal=document.getElementById('accessoriesModal'), c=document.getElementById('modalAccessoriesList');
      modal.classList.remove('hidden'); c.innerHTML='Yuklanmoqda...';
      try {
        const items=await fetchAPI('/api/accessories');
        if (!items.length){c.innerHTML='<div class="text-center text-gray-400 py-4">Aksessuar yo\'q</div>';return;}
        const groups={};
        items.forEach(i=>{if(!groups[i.productName])groups[i.productName]=[];groups[i.productName].push(i);});
        let html='';
        for(const[n,its]of Object.entries(groups)){html+=`<div class="mb-6"><h4 class="font-bold text-lg mb-2">📦 ${escapeHtml(n)}</h4><table class="w-full text-sm"><thead><tr class="bg-gray-100"><th class="p-2">Kod</th><th class="p-2 text-right">Soni</th><th class="p-2 text-right">Kg</th><th class="p-2 text-right">Metr</th></tr></thead><tbody>`;its.forEach(i=>{html+=`<tr><td class="p-2">${escapeHtml(i.code||'—')}</td><td class="p-2 text-right">${i.quantity??'—'}</td><td class="p-2 text-right">${i.kg??'—'}</td><td class="p-2 text-right">${i.meters??'—'}</td></tr>`;});html+=`</tbody></table></div>`;}
        c.innerHTML=html;
      } catch(e){c.innerHTML='<div class="text-red-500 text-center">Xatolik</div>';}
    }

    function closeModal(id){document.getElementById(id)?.classList.add('hidden');}

    // Fullscreen
    let currentFullscreenOverlay=null, overlayStorageListener=null;

    async function updateFullscreenStats(statsContainer) {
      try {
        const {products,incoming,expenses,staff,attendance,machines,accessories}=await fetchAllData();
        const dailyTotals=getDailyTotals(products);
        const todayTotal=BAND_TYPES.reduce((s,t)=>s+(dailyTotals[t]||0),0);
        const {present,absent,late,totalStaff}=getTodayStaffStats(staff,attendance);
        const {available,todayExpense}=computeWarehouseStats(incoming,expenses);
        const cards=statsContainer.querySelectorAll('.stats-card');
        if(cards.length===3){
          cards[0].innerHTML=`<h3>📊 Kunlik ishlar</h3><div class="stat-row"><span class="stat-label">Bugungi jami:</span><span class="stat-value">${todayTotal}</span></div><div class="stat-row"><span class="stat-label">🔥 Dazmol:</span><span class="stat-value">${dailyTotals['Dazmol']||0}</span></div><div class="stat-row"><span class="stat-label">📦 Upakovka:</span><span class="stat-value">${dailyTotals['Upakovka']||0}</span></div><div class="stat-row"><span class="stat-label">🖨️ Mashinalar:</span><span class="stat-value">${machines.length}</span></div>`;
          cards[1].innerHTML=`<h3>👥 Davomat</h3><div class="stat-row"><span class="stat-label">Jami:</span><span class="stat-value">${totalStaff}</span></div><div class="stat-row"><span class="stat-label">Kelganlar:</span><span class="stat-value">${present}</span></div><div class="stat-row"><span class="stat-label">Kelmaganlar:</span><span class="stat-value">${absent}</span></div><div class="stat-row"><span class="stat-label">⏰ Kech:</span><span class="stat-value">${late}</span></div>`;
          cards[2].innerHTML=`<h3>📦 Ombor</h3><div class="stat-row clickable" onclick="showIncomingModal()"><span class="stat-label">Mavjud:</span><span class="stat-value ${available<0?'negative-value':''}">${available}</span></div><div class="stat-row clickable" onclick="showExpenseModal()"><span class="stat-label">Kunlik chiqim:</span><span class="stat-value">${todayExpense}</span></div><div class="stat-row clickable" onclick="showAccessoriesModal()"><span class="stat-label">🔧 Aksessuarlar:</span><span class="stat-value">${accessories.length} tur</span></div>`;
        }
      } catch(err){console.error('Fullscreen stats error:',err);}
    }

    async function showFullscreenChart(chartInstance, chartCanvas, chartCard) {
      if (currentFullscreenOverlay) return;
      if (!chartInstance || !chartCanvas) return;

      const overlay=document.createElement('div');
      overlay.className='fullscreen-overlay';

      const video=document.createElement('video');
      video.id='bgVideo'; video.autoplay=true; video.loop=true; video.muted=true; video.playsInline=true; video.preload='auto';
      video.src='/videos/bg.mp4';
      video.style.filter='brightness(0.7)';
      video.onerror=()=>{ overlay.style.background='radial-gradient(ellipse at 30% 40%, #0a2f4a, #031e2f)'; };
      overlay.appendChild(video);

      const statsContainer=document.createElement('div');
      statsContainer.className='stats-cards-container';
      for(let i=0;i<3;i++){const card=document.createElement('div');card.className='stats-card';card.innerHTML='<h3>📊 Yuklanmoqda...</h3>';statsContainer.appendChild(card);}

      const chartWrapper=document.createElement('div');
      chartWrapper.className='chart-wrapper';
      const originalParent=chartCanvas.parentNode;
      chartCanvas.height=1200;

      const {products}=await fetchAllData();
      const dailyTotals=getDailyTotals(products);
      const dailyTotal=BAND_TYPES.reduce((sum,type)=>sum+(dailyTotals[type]||0),0);

      if(dailyTotal===0){
        const msg=document.createElement('div');
        msg.style.cssText='display:flex;align-items:center;justify-content:center;height:100%;text-align:center;flex-direction:column;color:white;';
        msg.innerHTML='<div style="font-size:3rem;margin-bottom:1rem;">📭</div><h2 style="font-size:1.5rem;">Bugun hali maʼlumot qo\'shilmagan</h2>';
        chartWrapper.appendChild(msg);
      } else {
        chartWrapper.appendChild(chartCanvas);
      }

      await updateFullscreenStats(statsContainer);

      const closeBtn=document.createElement('button');
      closeBtn.innerHTML='✖'; closeBtn.className='close-fullscreen';
      closeBtn.onclick=()=>document.exitFullscreen();

      overlay.appendChild(closeBtn);
      overlay.appendChild(statsContainer);
      overlay.appendChild(chartWrapper);

      const marqueeFooter=document.createElement('div');
      marqueeFooter.className='marquee-footer';
      marqueeFooter.innerHTML='<div class="marquee-text">✨ Created by <strong>Makhmudov</strong> ✨ Ombor statistikasi | Real-time data visualization ✨</div>';
      document.body.appendChild(marqueeFooter);
      document.body.appendChild(overlay);
      currentFullscreenOverlay={overlay,chartCanvas,originalParent,chartInstance,statsContainer,marqueeFooter};

      video.play().catch(e=>console.warn('Video autoplay blocked',e));

      overlay.requestFullscreen().catch(err=>console.error('Fullscreen error:',err)).then(()=>{
        setTimeout(()=>{chartInstance.resize();chartInstance.update();},100);
      });

      overlayStorageListener=async()=>{ if(currentFullscreenOverlay?.statsContainer) await updateFullscreenStats(currentFullscreenOverlay.statsContainer); };
      window.addEventListener('storage',overlayStorageListener);

      const fsChangeHandler=()=>{
        if(!document.fullscreenElement && currentFullscreenOverlay){
          const{chartCanvas,originalParent,chartInstance,overlay,marqueeFooter}=currentFullscreenOverlay;
          originalParent.appendChild(chartCanvas);
          overlay.remove();
          if(marqueeFooter)marqueeFooter.remove();
          // ✅ FIX 2: destroy + canvas height sıfırla + re-render
          if(chartInstance){
            chartInstance.destroy();
            const ctx=chartCanvas.getContext('2d');
            if(ctx) ctx.clearRect(0,0,chartCanvas.width,chartCanvas.height);
            if(chartCanvas.id==='quantityChart'){chartCanvas.height=500;mainChart=null;}
            else if(chartCanvas.id==='yearlyChart'){chartCanvas.height=300;yearlyChart=null;}
          }
          setTimeout(async()=>{
            const data=await fetchAllData();
            if(chartCanvas.id==='quantityChart') renderMainChart(data.products);
            else if(chartCanvas.id==='yearlyChart') renderYearlyChart(data.products);
          },100);
          currentFullscreenOverlay=null;
          if(overlayStorageListener) window.removeEventListener('storage',overlayStorageListener);
          document.removeEventListener('fullscreenchange',fsChangeHandler);
        } else if(document.fullscreenElement){
          setTimeout(()=>{chartInstance.resize();chartInstance.update();},100);
        }
      };
      document.addEventListener('fullscreenchange',fsChangeHandler);
    }

    function bindFullscreenButtons() {
      const mainBtn=document.getElementById('fullscreenMainBtn');
      const yearlyBtn=document.getElementById('fullscreenYearlyBtn');
      const mainCanvas=document.getElementById('quantityChart');
      const yearlyCanvas=document.getElementById('yearlyChart');
      if(mainBtn&&mainCanvas) mainBtn.addEventListener('click',()=>{ if(mainChart) showFullscreenChart(mainChart,mainCanvas,document.getElementById('mainChartCard')); });
      if(yearlyBtn&&yearlyCanvas) yearlyBtn.addEventListener('click',()=>{ if(yearlyChart) showFullscreenChart(yearlyChart,yearlyCanvas,document.getElementById('yearlyChartCard')); });
    }

    async function refreshAll() {
      try {
        const dateKey = getSelectedDateKey();
        const {products,incoming,expenses,staff,attendance,machines,accessories}=await fetchAllData();
        const totalAll=products.filter(p=>BAND_TYPES.includes(p.productType)).reduce((s,p)=>s+p.quantity,0);
        const dailyTotals=getDailyTotals(products, dateKey);
        const dailyTotal=BAND_TYPES.reduce((sum,type)=>sum+(dailyTotals[type]||0),0);

        const setEl=(id,val)=>{const el=document.getElementById(id);if(el)el.innerText=val;};
        setEl('totalSumStat',totalAll);
        setEl('dailySumStat',dailyTotal);

        const extra=getExtraStats(products);
        setEl('dazmolTotal',extra.dazmolAll);
        setEl('upakovkaTotal',extra.upakovkaAll);

        const allTimeBands=aggregateAllTimeBands(products);
        let topBand=null, topQty=0;
        for(const[band,qty]of Object.entries(allTimeBands)) if(qty>topQty){topQty=qty;topBand=band;}
        setEl('topBandName',topBand||'—');
        setEl('topBandQty',topQty);

        const{available,todayExpense}=computeWarehouseStats(incoming,expenses);
        const availSpan=document.getElementById('availableWorkStat');
        if(availSpan){availSpan.innerText=available;available<0?availSpan.classList.add('negative-value'):availSpan.classList.remove('negative-value');}
        setEl('dailyExpenseStat',todayExpense);
        setEl('accessoriesCountStat',accessories.length);

        renderMainChart(products, dateKey);
        renderYearlyChart(products);
        const last30=aggregateLast30Days(products);
        renderBandBarChart(last30);
        renderRanking(last30);
        renderExtraStats(extra.upakovkaAll,extra.upakovka30,extra.dazmolAll,extra.dazmol30);
        renderMonthlyTable(incoming,expenses);

        document.querySelectorAll('.stats-card').forEach(card=>{
          card.classList.add('refresh-pulse');
          setTimeout(()=>card.classList.remove('refresh-pulse'),500);
        });

        if(currentFullscreenOverlay?.statsContainer){
          await updateFullscreenStats(currentFullscreenOverlay.statsContainer);
          try{currentFullscreenOverlay.chartInstance?.update();}catch(e){}
        }
      } catch(err){console.error('refreshAll error:',err);}
    }

    function setupDailyReset() {
      const today=getTodayKey();
      if(localStorage.getItem('lastActiveDate')!==today) localStorage.setItem('lastActiveDate',today);
      const now=new Date();
      const tomorrow=new Date(now);
      tomorrow.setDate(tomorrow.getDate()+1);
      tomorrow.setHours(0,0,0,0);
      setTimeout(()=>location.reload(), tomorrow.getTime()-now.getTime());
    }

    function loadNotes() {
      const notes=JSON.parse(localStorage.getItem('grafikNotes')||'[]');
      const div=document.getElementById('savedNotes');
      div.innerHTML=notes.map((n,i)=>`<div class="bg-yellow-50 p-2 rounded mb-2 flex justify-between items-center"><span>${escapeHtml(n.text)}</span><small class="text-gray-500">${new Date(n.date).toLocaleString('uz-UZ')}</small><button onclick="deleteNote(${i})" class="text-red-500 ml-2">✖</button></div>`).join('');
    }
    function saveNote(text){const notes=JSON.parse(localStorage.getItem('grafikNotes')||'[]');notes.push({text,date:new Date().toISOString()});localStorage.setItem('grafikNotes',JSON.stringify(notes));loadNotes();}
    function deleteNote(i){const notes=JSON.parse(localStorage.getItem('grafikNotes')||'[]');notes.splice(i,1);localStorage.setItem('grafikNotes',JSON.stringify(notes));loadNotes();}
    window.deleteNote=deleteNote;

    function escapeHtml(str){if(!str)return'';return str.replace(/[&<>]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[m]));}

    document.addEventListener('DOMContentLoaded',()=>{
      const lo=document.getElementById('loadingOverlay');
      if(lo)lo.style.display='none';
      setupDailyReset();
      refreshAll();
      bindFullscreenButtons();
      setInterval(refreshAll,30000);

      const dateInput = document.getElementById('graphDateFilter');
      if (dateInput) {
        dateInput.value = getTodayKey();
        dateInput.addEventListener('change', () => {
          if (!dateInput.value) dateInput.value = getTodayKey();
          refreshAll();
        });
      }
      document.getElementById('dateResetBtn')?.addEventListener('click', () => {
        const input = document.getElementById('graphDateFilter');
        if (input) {
          input.value = getTodayKey();
          refreshAll();
        }
      });
      document.getElementById('availableWorkRow')?.addEventListener('click',showIncomingModal);
      document.getElementById('dailyExpenseRow')?.addEventListener('click',showExpenseModal);
      document.getElementById('accessoriesRow')?.addEventListener('click',showAccessoriesModal);
      document.querySelectorAll('.close-modal').forEach(btn=>btn.addEventListener('click',()=>{const id=btn.getAttribute('data-modal');if(id)closeModal(id);}));
      window.addEventListener('click',e=>{if(e.target.classList.contains('modal-overlay'))e.target.classList.add('hidden');});

      document.getElementById('noteBtn').addEventListener('click',()=>{document.getElementById('noteModal').classList.remove('hidden');loadNotes();});
      document.getElementById('aiSummaryBtn')?.addEventListener('click', requestAISummary);
      document.getElementById('saveNoteBtn').addEventListener('click',()=>{const t=document.getElementById('noteText').value.trim();if(t){saveNote(t);document.getElementById('noteText').value='';}});
      document.getElementById('clearNoteBtn').addEventListener('click',()=>{localStorage.removeItem('grafikNotes');loadNotes();});
    });

    window.showIncomingModal=showIncomingModal;
    window.showExpenseModal=showExpenseModal;
    window.showAccessoriesModal=showAccessoriesModal;
  </script>
</body>
</html>