<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" integrity="sha512-hZB4mZgRfb83Av4G2Mq2/vL0DdRuE+Xj2btDbo5RutMDw3ZzQGwmybL1j1aWYNDsBfFEduY3S7+veMSKixnJIg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" integrity="sha512-iuqkISYrA9A2qZcXa/Ef25FOF6Jy6p8ChyrnTKbC2wQd75d34bdD+TJ+38t8SIHh7fYMSYy9YrC8EtVxUCyrFg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <title>BestTex Admin</title>
    <style>
        /* Loader animatsiyalari butunlay olib tashlandi */
        
        .navbar {
            background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(248,250,252,0.95) 100%);
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .nav-btn-desktop {
            @apply px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 border-2 border-transparent text-slate-700 hover:border-blue-500 hover:bg-blue-50 active:scale-95 relative overflow-hidden;
        }
        .nav-btn-desktop::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(59, 130, 246, 0.1);
            transition: left 0.3s ease;
        }
        .nav-btn-desktop:hover::before { left: 100%; }
        .nav-btn-desktop span { position: relative; z-index: 1; }

        .active-desktop {
            @apply bg-gradient-to-r from-blue-600 to-blue-700 border-blue-600 text-white shadow-lg shadow-blue-300 hover:shadow-blue-400 !important;
        }

        #mobileSidebar.hidden-sidebar {
            visibility: hidden;
            opacity: 0;
            transition: opacity 0.3s ease, visibility 0.3s ease;
        }
        #mobileSidebar.show-sidebar {
            visibility: visible;
            opacity: 1;
            transition: opacity 0.3s ease, visibility 0.3s ease;
        }
        #sidebarContent {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: -10px 0 40px rgba(0,0,0,0.15);
        }
        .hidden-content { transform: translateX(100%); }
        .show-content { transform: translateX(0); }

        .sidebar-link {
            @apply flex items-center gap-4 p-4 rounded-2xl text-slate-700 transition-all duration-300 relative;
        }
        .sidebar-link::before {
            content: '';
            position: absolute;
            left: 0;
            width: 3px;
            height: 0;
            background: linear-gradient(180deg, #3b82f6, #1e40af);
            transition: height 0.3s ease;
            border-radius: 0 3px 3px 0;
        }
        .sidebar-link:hover { background-color: rgba(59, 130, 246, 0.1); }
        .sidebar-link:hover::before { height: 100%; }
        .sidebar-link.active { background: linear-gradient(135deg, #dbeafe, #eff6ff); color: #1e40af; }

        @keyframes toast-slide-in {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        @keyframes toast-fade-out {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(20px); visibility: hidden; }
        }
        .telegram-toast {
            animation: toast-slide-in 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
        }
        .telegram-toast.hide-toast {
            animation: toast-fade-out 0.3s ease forwards;
        }

        @media (max-width: 640px) {
            nav { padding: 0.5rem 1rem; }
            .navbar { padding: 0.5rem 1rem; }
            #sidebarContent { width: 100%; padding: 1rem; }
            .sidebar-link { padding: 1rem; font-size: 1rem; }
            .nav-btn-desktop { padding: 0.5rem 1rem; font-size: 0.75rem; }
        }
        /* Scroll reveal / entrance animations (global) */
        .sr-item { opacity: 0; transform: translateY(20px); transition: opacity var(--sr-duration,800ms) cubic-bezier(0.22, 1, 0.36, 1) var(--sr-delay,0ms), transform var(--sr-duration,800ms) cubic-bezier(0.22, 1, 0.36, 1) var(--sr-delay,0ms); will-change: opacity, transform; }
        .sr-in { opacity: 1; transform: none; }
        .sr-fade-up { transform: translateY(22px); }
        .sr-fade-left { transform: translateX(20px); }
        .sr-fade-right { transform: translateX(-20px); }
        [data-sr] { --sr-duration: 800ms; --sr-delay: 0ms; }
        @media (prefers-reduced-motion: reduce) { .sr-item { transition: none !important; transform: none !important; opacity: 1 !important; } }
    </style>
</head>
<body class="min-h-screen bg-slate-50 font-sans text-slate-900">

<!-- Navbar -->
<nav class="navbar fixed top-0 left-0 right-0 z-50 px-4 py-3 border-b border-gray-100">
    <div class="max-w-[1440px] mx-auto flex items-center justify-between">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
            <div class="bg-red-700 p-1.5 rounded-lg">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>
            </div>
            <span class="font-bold text-slate-800 tracking-tight hidden sm:inline">THE BEST TEX</span>
        </a>

        <!-- Desktop Menu -->
        <div class="hidden lg:flex items-center gap-4">
            <a href="/" class="nav-btn-desktop active-desktop" title="Tikuv soni"><span>Tikuv soni</span></a>
            <a href="/grafik" class="nav-btn-desktop" title="Statistika"><span>Statistika</span></a>
            <a href="/qrNames" class="nav-btn-desktop" title="QR Nomlar"><span>Tikuv kirim</span></a>
            <a href="/kesimXona" class="nav-btn-desktop" title="Kirim"><span>Kirim</span></a>
            <a href="/chiqim" class="nav-btn-desktop" title="Chiqim"><span>Chiqim</span></a>
            <a href="/kadrlar" class="nav-btn-desktop" title="Kadrlar"><span>Kadrlar</span></a>
            <a href="/davomat" class="nav-btn-desktop" title="Davomat"><span>Davomat</span></a>
            <a href="/mashinkalar" class="nav-btn-desktop" title="Mashinalar"><span>Mashinalar</span></a>
            <a href="/aksessuar" class="nav-btn-desktop" title="Aksessuar"><span>Aksessuar</span></a>
            
        </div>

        <!-- O'ng tomon -->
        <div class="flex items-center gap-2">
            <button id="testAnnounceBtnDesktop" class="hidden md:block bg-slate-800 hover:bg-blue-600 text-white text-xs font-semibold px-5 py-2.5 rounded-full transition-all active:scale-90">
                🔊 Test ovoz
            </button>
            <button onclick="toggleMenu(true)" class="lg:hidden p-2.5 rounded-xl bg-gray-100 text-slate-700 hover:bg-gray-200 active:scale-90 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile/Tablet Sidebar -->
<div id="mobileSidebar" class="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-sm hidden-sidebar transition-all duration-300">
    <div class="absolute inset-0" onclick="toggleMenu(false)"></div>

    <div id="sidebarContent" class="absolute right-0 top-0 bottom-0 w-[280px] sm:w-[300px] bg-white shadow-2xl p-6 hidden-content flex flex-col">
        <div class="flex justify-between items-center mb-8">
            <h2 class="font-bold text-xl text-slate-800 tracking-tight">Menyu</h2>
            <button onclick="toggleMenu(false)" class="p-2 rounded-full bg-red-50 text-red-600 hover:bg-red-100 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="flex flex-col gap-2 overflow-y-auto flex-grow">
            <a href="/" class="sidebar-link active"><span class="text-lg">🏠</span> <span>Asosiy</span></a>
            <a href="/grafik" class="sidebar-link"><span class="text-lg">📊</span> <span>Statistika</span></a>
            <a href="/qrNames" class="sidebar-link"><span class="text-lg">📱</span> <span>Tikuv kirim</span></a>
            <a href="/kesimXona" class="sidebar-link"><span class="text-lg">📥</span> <span>Kroy kirim</span></a>
            <a href="/chiqim" class="sidebar-link"><span class="text-lg">📤</span> <span>Kroy chiqim</span></a>
            <a href="/kadrlar" class="sidebar-link"><span class="text-lg">👥</span> <span>Kadrlar</span></a>
            <a href="/davomat" class="sidebar-link"><span class="text-lg">📅</span> <span>Davomat</span></a>
            <a href="/mashinkalar" class="sidebar-link"><span class="text-lg">⚙️</span> <span>Mashinalar</span></a>
            <a href="/aksessuar" class="sidebar-link"><span class="text-lg">🧵</span> <span>Aksessuar</span></a>
            
            <a href="/mikrafon" class="sidebar-link"><span class="text-lg">🎤</span> <span>Mikrafon</span></a>
        </div>

        <div class="pt-6 border-t border-gray-100">
            <button id="testAnnounceBtnMobile" class="w-full py-4 bg-gradient-to-r from-slate-900 to-slate-800 text-white rounded-2xl font-bold active:scale-95 transition-all duration-200 hover:shadow-lg hover:shadow-slate-900/20">
                🔊 Test Ovoz
            </button>
        </div>
    </div>
</div>

<script>
    // Telegram daily toast
    (function() {
        function showTelegramDailyToast() {
            const todayKey = new Date().toISOString().slice(0,10);
            const lastDate = localStorage.getItem('telegramToastLastDate');
            if (lastDate === todayKey) return;

            const toast = document.createElement('div');
            toast.className = 'telegram-toast fixed bottom-5 right-5 z-50 bg-white rounded-2xl shadow-2xl border-l-4 border-blue-500 max-w-sm w-full';
            toast.innerHTML = `
              <div class="flex items-start p-4 gap-3">
                <div class="bg-blue-100 rounded-full p-2">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="font-semibold text-gray-900 text-sm">📡 Telegram kuzatuv</p>
                  <p class="text-sm text-gray-600">Maʼlumotlarni Telegram bot orqali kuzatib boring.<br>Statistika, kirim-chiqim, kadrlar — hamma narsa qoʻlingizda.</p>
                </div>
                <button class="close-toast text-gray-400 hover:text-gray-600">&times;</button>
              </div>
              <div class="bg-blue-50 px-4 py-2 text-xs text-blue-700 rounded-b-2xl">
                🤖 @PaxtabodBot | Kunlik eslatma
              </div>
            `;
            document.body.appendChild(toast);

            const closeBtn = toast.querySelector('.close-toast');
            const hide = () => {
                toast.classList.add('hide-toast');
                setTimeout(() => toast.remove(), 300);
            };
            closeBtn.onclick = hide;
            setTimeout(hide, 8000);

            localStorage.setItem('telegramToastLastDate', todayKey);
        }

        window.addEventListener('load', () => {
            setTimeout(showTelegramDailyToast, 1500);
        });
    })();

    // Sidebar menyuni boshqarish
    function toggleMenu(open) {
        const sidebar = document.getElementById('mobileSidebar');
        const content = document.getElementById('sidebarContent');

        if (open) {
            sidebar.classList.replace('hidden-sidebar', 'show-sidebar');
            content.classList.replace('hidden-content', 'show-content');
            document.body.style.overflow = 'hidden';
        } else {
            content.classList.replace('show-content', 'hidden-content');
            setTimeout(() => {
                sidebar.classList.replace('show-sidebar', 'hidden-sidebar');
                document.body.style.overflow = '';
            }, 300);
        }
    }

    const audio = new Audio('/sounds/sound.mp3');

    function playSound(times) {
        let count = 0;
        function playNext() {
            if (count < times) {
                audio.currentTime = 0;
                audio.play().catch(err => console.error(err));
                count++;
                audio.onended = () => {
                    setTimeout(playNext, 3000);
                };
            }
        }
        playNext();
    }

    // Test ovoz tugmalari
    document.addEventListener('DOMContentLoaded', () => {
        const desktopBtn = document.getElementById('testAnnounceBtnDesktop');
        const mobileBtn = document.getElementById('testAnnounceBtnMobile');

        if (desktopBtn) desktopBtn.addEventListener('click', () => playSound(1));
        if (mobileBtn) mobileBtn.addEventListener('click', () => playSound(1));
    });

    // Kunlik ovozli xabarlar jadvali
    function scheduleDailySounds() {
        const now = new Date();
        const today = now.toDateString();

        // 07:55 — ishga 5 daqiqa qoldi (10 marta)
        const preMorning = new Date(today + ' 07:55:00');
        if (now < preMorning) {
            setTimeout(() => playSound(10), preMorning - now);
        }

        // 08:00 — ish boshlandi (5 marta)
        const morning = new Date(today + ' 08:00:00');
        if (now < morning) {
            setTimeout(() => playSound(5), morning - now);
        }

        // 12:00 — tushlik boshlandi (5 marta)
        const noon = new Date(today + ' 12:00:00');
        if (now < noon) {
            setTimeout(() => playSound(5), noon - now);
        }

        // 12:55 — tushlikdan qaytish (10 marta)
        const preAfternoon = new Date(today + ' 12:55:00');
        if (now < preAfternoon) {
            setTimeout(() => playSound(10), preAfternoon - now);
        }

        // 13:00 — tushlikdan keyin ish (5 marta)
        const afternoon = new Date(today + ' 13:00:00');
        if (now < afternoon) {
            setTimeout(() => playSound(5), afternoon - now);
        }

        // 17:55 — ish tugashiga 5 daqiqa qoldi (15 marta)
        const preEvening = new Date(today + ' 18:10:00');
        if (now < preEvening) {
            setTimeout(() => playSound(1), preEvening - now);
        }

        // 18:00 — ish tugadi (5 marta)
        const evening = new Date(today + ' 18:00:00');
        if (now < evening) {
            setTimeout(() => playSound(5), evening - now);
        }

        // Ertangi kun uchun jadvalni qayta ishga tushirish
        const tomorrow = new Date(now);
        tomorrow.setDate(tomorrow.getDate() + 1);
        tomorrow.setHours(0, 0, 0, 0);
        setTimeout(scheduleDailySounds, tomorrow - now);
    }

    window.addEventListener('load', () => {
        scheduleDailySounds();
    });

    /* GSAP page and scroll animations for a smoother whole-page experience */
    (function(){
        if (!window.gsap || !window.ScrollTrigger) return;
        gsap.registerPlugin(ScrollTrigger);

        function isIgnored(el) {
            return !el || el.nodeType !== 1 || el.closest('nav, footer, #mobileSidebar, .toast-container, .modal-overlay, .no-sr, [data-sr-ignore]');
        }

        function animatePageLoad() {
            const pageContainers = Array.from(document.querySelectorAll('body > div:not(#mobileSidebar):not(.toast-container):not(.modal-overlay)'))
                .filter(el => !isIgnored(el));
            gsap.from(pageContainers, {
                duration: 1,
                opacity: 0,
                y: 30,
                ease: 'power3.out',
                stagger: 0.08,
                delay: 0.12,
            });

            const nav = document.querySelector('.navbar');
            if (nav) {
                gsap.from(nav, { duration: 0.85, opacity: 0, y: -28, ease: 'power3.out' });
            }
        }

        function animateScrollElements() {
            const items = gsap.utils.toArray('main, section, .chart-card, .stats-card, .ranking-card, .form-group, .input-group, .table, .content, .content-wrapper, .page-wrapper, .page-shell, .page-container');
            items.forEach(item => {
                if (isIgnored(item)) return;
                ScrollTrigger.create({
                    trigger: item,
                    start: 'top 92%',
                    toggleActions: 'play none none none',
                    once: true,
                    onEnter: () => {
                        gsap.fromTo(item, { opacity: 0, y: 22 }, { duration: 0.8, opacity: 1, y: 0, ease: 'power3.out' });
                    }
                });
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            animatePageLoad();
            animateScrollElements();
        });

        window.initPageAnimations = function(context = document) {
            gsap.utils.toArray('main, section, .chart-card, .stats-card, .ranking-card, .form-group, .input-group, .table, .content, .content-wrapper, .page-wrapper, .page-shell, .page-container', context).forEach(item => {
                if (isIgnored(item)) return;
                gsap.fromTo(item, { opacity: 0, y: 22 }, { duration: 0.8, opacity: 1, y: 0, ease: 'power3.out', scrollTrigger: { trigger: item, start: 'top 92%', toggleActions: 'play none none none' } });
            });
        };
    })();
</script>

</body>
</html>