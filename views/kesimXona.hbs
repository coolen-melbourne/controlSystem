<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>{{title}} | Kirim</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #f2f2f7; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; }
    .ios-card { background: white; border-radius: 1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.03); }
    .thumb { width: 40px; height: 40px; object-fit: cover; border-radius: 8px; background: #f3f4f6; }
  </style>
</head>
<body class="antialiased">

{{> navbar}}

<div class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 pb-10">
  <h1 class="text-2xl font-semibold mb-6 text-center tracking-tight">Yangi Ish Qabul Qilish</h1>

  <!-- Stats cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="ios-card p-4 flex items-center gap-3 shadow-sm">
      <div class="bg-blue-100 p-3 rounded-full"><span class="text-2xl">📦</span></div>
      <div><p class="text-xs text-gray-500 uppercase tracking-wide">Mavjud ish soni</p><p id="availableWorkCount" class="text-2xl font-bold text-gray-800">0</p></div>
    </div>
    <div class="ios-card p-4 flex items-center gap-3 shadow-sm">
      <div class="bg-orange-100 p-3 rounded-full"><span class="text-2xl">📉</span></div>
      <div><p class="text-xs text-gray-500 uppercase tracking-wide">Kunlik chiqim soni</p><p id="dailyExpenseCount" class="text-2xl font-bold text-gray-800">0</p></div>
    </div>
  </div>

  <div class="ios-card p-6 mb-8">
    <form id="productForm" class="space-y-5">
      <div class="flex flex-col items-center justify-center p-6 border-2 border-dashed border-gray-300 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-colors cursor-pointer" onclick="document.getElementById('imageInput').click()">
        <svg class="w-8 h-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
        <span class="text-sm text-gray-500 font-medium">Rasm yuklash (Ixtiyoriy)</span>
        <input type="file" id="imageInput" class="hidden" accept="image/*">
        <div id="imagePreview" class="mt-2 hidden"><img class="thumb w-16 h-16 object-cover rounded-lg"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div><label class="block text-sm font-medium text-gray-600 mb-1.5">Model nomi</label><input type="text" id="modelName" required class="w-full bg-gray-100 rounded-xl px-4 py-3 focus:ring-2 focus:ring-blue-500/50"></div>
        <div><label class="block text-sm font-medium text-gray-600 mb-1.5">Variant (Rang/O'lcham)</label><input type="text" id="variant" required class="w-full bg-gray-100 rounded-xl px-4 py-3"></div>
        <div><label class="block text-sm font-medium text-gray-600 mb-1.5">Zakaz nomeri</label><input type="text" id="orderNumber" required class="w-full bg-gray-100 rounded-xl px-4 py-3"></div>
        <div><label class="block text-sm font-medium text-gray-600 mb-1.5">Nechta ish kelgani</label><input type="number" id="quantity" required min="1" class="w-full bg-gray-100 rounded-xl px-4 py-3"></div>
      </div>

      <div class="flex items-center justify-between bg-gray-100 rounded-xl px-4 py-3">
        <span class="text-sm font-medium text-gray-700">Aksessuarlar bormi?</span>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="hasAccessory" class="sr-only peer">
          <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#34C759]"></div>
        </label>
      </div>

      <button type="submit" class="w-full bg-[#007AFF] hover:bg-blue-600 text-white font-semibold rounded-xl py-3.5 transition-colors active:scale-[0.98]">Qo'shish / Checkout</button>
    </form>
  </div>

  <h2 class="text-xl font-semibold mb-4">Qabul qilingan mahsulotlar</h2>
  <div class="ios-card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse hidden md:table">
        <thead><tr class="bg-gray-50 text-gray-500 text-xs uppercase"><th class="px-4 py-3">Rasm</th><th>Model & Variant</th><th>Zakaz #</th><th>Soni</th><th>Aksessuar</th><th>Sana</th><th class="text-right">Amallar</th> </tr></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div id="mobileList" class="md:hidden divide-y divide-gray-100"></div>
  </div>
</div>

<script>
  let products = [];
  let editId = null;

  async function loadProducts() {
    const res = await fetch('/api/incoming');
    products = await res.json();
    renderData();
    updateStats();
  }

  async function saveProduct(productData) {
    if (editId !== null) {
      await fetch(`/api/incoming/${editId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(productData)
      });
    } else {
      await fetch('/api/incoming', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(productData)
      });
    }
    loadProducts();
  }

  async function deleteProduct(id) {
    if (!confirm("O‘chirilsinmi?")) return;
    await fetch(`/api/incoming/${id}`, { method: 'DELETE' });
    loadProducts();
  }

  function editProduct(id) {
    const p = products.find(p => p._id === id);
    if (!p) return;
    document.getElementById('modelName').value = p.modelName;
    document.getElementById('variant').value = p.variant;
    document.getElementById('orderNumber').value = p.orderNumber;
    document.getElementById('quantity').value = p.quantity;
    document.getElementById('hasAccessory').checked = p.hasAccessory;
    if (p.imageData) {
      const preview = document.getElementById('imagePreview');
      preview.classList.remove('hidden');
      preview.querySelector('img').src = p.imageData;
    } else {
      document.getElementById('imagePreview').classList.add('hidden');
    }
    editId = id;
    document.querySelector('button[type="submit"]').textContent = "O'zgarishlarni saqlash";
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  async function updateStats() {
    const res = await fetch('/api/stats/today');
    const stats = await res.json();
    document.getElementById('availableWorkCount').innerText = stats.availableWork;
    document.getElementById('dailyExpenseCount').innerText = stats.expenseToday;
  }

  function renderData() {
    const tbody = document.getElementById('tableBody');
    const mobile = document.getElementById('mobileList');
    tbody.innerHTML = '';
    mobile.innerHTML = '';
    if (!products.length) {
      tbody.innerHTML = `<td colspan="7" class="text-center py-8 text-gray-400">Maʼlumot yo‘q</tr>`;
      mobile.innerHTML = '<div class="p-8 text-center text-gray-400">Maʼlumot yo‘q</div>';
      return;
    }
    products.forEach(p => {
      const accessoryBadge = p.hasAccessory ? '<span class="px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full">Bor</span>' : '<span class="px-2 py-0.5 text-xs bg-gray-100 text-gray-600 rounded-full">Yo‘q</span>';
      const imgHtml = p.imageData ? `<img src="${p.imageData}" class="thumb w-10 h-10 object-cover rounded">` : '<div class="w-10 h-10 bg-gray-200 rounded flex items-center justify-center text-gray-400">📷</div>';
      const tr = document.createElement('tr');
      tr.className = "border-b border-gray-100 hover:bg-gray-50";
      tr.innerHTML = `
        <td class="px-4 py-3">${imgHtml}</td>
        <td class="px-4 py-3"><div class="font-medium">${escapeHtml(p.modelName)}</div><div class="text-xs text-gray-500">${escapeHtml(p.variant)}</div></td>
        <td class="px-4 py-3">${escapeHtml(p.orderNumber)}</td>
        <td class="px-4 py-3">${p.quantity} dona</td>
        <td class="px-4 py-3">${accessoryBadge}</td>
        <td class="px-4 py-3 text-xs text-gray-500">${new Date(p.date).toLocaleString()}</td>
        <td class="px-4 py-3 text-right space-x-2"><button onclick="editProduct('${p._id}')" class="text-blue-600 text-sm">Tahrir</button><button onclick="deleteProduct('${p._id}')" class="text-red-600 text-sm">O‘chir</button></td>
      `;
      tbody.appendChild(tr);
      const card = document.createElement('div');
      card.className = "p-4 border-b border-gray-100";
      card.innerHTML = `
        <div class="flex items-start gap-3">
          ${imgHtml}
          <div class="flex-1">
            <div class="font-semibold">${escapeHtml(p.modelName)} <span class="text-xs text-gray-500">${escapeHtml(p.variant)}</span></div>
            <div class="text-xs text-gray-500">Zakaz: ${escapeHtml(p.orderNumber)} · ${p.quantity} dona</div>
            <div class="text-xs mt-1">${accessoryBadge} · ${new Date(p.date).toLocaleString()}</div>
            <div class="mt-2 space-x-3"><button onclick="editProduct('${p._id}')" class="text-blue-600 text-sm">Tahrir</button><button onclick="deleteProduct('${p._id}')" class="text-red-600 text-sm">O‘chir</button></div>
          </div>
        </div>
      `;
      mobile.appendChild(card);
    });
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[m]));
  }

  document.getElementById('productForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const modelName = document.getElementById('modelName').value;
    const variant = document.getElementById('variant').value;
    const orderNumber = document.getElementById('orderNumber').value;
    const quantity = parseInt(document.getElementById('quantity').value);
    const hasAccessory = document.getElementById('hasAccessory').checked;
    let imageData = '';
    const imgPreview = document.getElementById('imagePreview').querySelector('img');
    if (imgPreview && imgPreview.src) imageData = imgPreview.src;

    await saveProduct({ modelName, variant, orderNumber, quantity, hasAccessory, imageData });
    document.getElementById('productForm').reset();
    document.getElementById('imagePreview').classList.add('hidden');
    editId = null;
    document.querySelector('button[type="submit"]').textContent = "Qo'shish / Checkout";
  });

  document.getElementById('imageInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
      const previewDiv = document.getElementById('imagePreview');
      const img = previewDiv.querySelector('img');
      img.src = ev.target.result;
      previewDiv.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
  });

  loadProducts();
  window.editProduct = editProduct;
  window.deleteProduct = deleteProduct;

    // Yangi: rasmni avtomatik kichraytirish funksiyasi
  function compressImage(file, maxWidth = 800, maxHeight = 800, quality = 0.7) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = (e) => {
        const img = new Image();
        img.src = e.target.result;
        img.onload = () => {
          let width = img.width;
          let height = img.height;
          if (width > maxWidth || height > maxHeight) {
            if (width > height) {
              height = (height * maxWidth) / width;
              width = maxWidth;
            } else {
              width = (width * maxHeight) / height;
              height = maxHeight;
            }
          }
          const canvas = document.createElement('canvas');
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          const compressedBase64 = canvas.toDataURL('image/jpeg', quality);
          resolve(compressedBase64);
        };
        img.onerror = (err) => reject(err);
      };
      reader.onerror = (err) => reject(err);
    });
  }

  // Rasm yuklash hodisasi – avtomatik siqish
  document.getElementById('imageInput').addEventListener('change', async function(e) {
    const file = e.target.files[0];
    if (!file) return;
    
    // Agar fayl 2MB dan katta bo‘lsa, ogohlantirish (ixtiyoriy)
    if (file.size > 2 * 1024 * 1024) {
      alert("Rasm hajmi 2MB dan katta. Avtomatik kichraytiriladi...");
    }
    
    try {
      // Rasmni kichraytirish (maks 800px, sifat 0.7)
      const compressedBase64 = await compressImage(file, 800, 800, 0.7);
      // Yuklangan rasmdan oldingi previewni yangilash
      const previewDiv = document.getElementById('imagePreview');
      const imgElement = previewDiv.querySelector('img');
      imgElement.src = compressedBase64;
      previewDiv.classList.remove('hidden');
      // Keyinchalik form submit qilinganda ushbu compressedBase64 saqlanadi
      // Buning uchun hidden input yoki o‘zgaruvchi ishlatish kerak.
      // Mavjud kodda imageData to‘g‘ridan-to‘g‘ri img.src dan olinadi, shuning uchun yetarli.
    } catch (err) {
      console.error("Rasmni kichraytirishda xato:", err);
      alert("Rasmni qayta ishlashda xato yuz berdi.");
    }
  });
</script>
</body>
</html>